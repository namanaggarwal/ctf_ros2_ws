Panels:
  - Class: rviz_common/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Benchmarking1/Trajectories1/Namespaces1
        - /NX011/Planning1/NX01 Traj1/Topic1
        - /NX011/Mapping1/NX01 D435 PointCloud1/Topic1
        - /NX011/Mapping1/NX01 Lidar PointCloud1/Topic1
        - /NX011/Others1
      Splitter Ratio: 0.5
    Tree Height: 917
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: NX01 ACL Map Occupied
